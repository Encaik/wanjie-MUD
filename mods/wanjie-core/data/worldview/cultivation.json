  "factions": [
    { "id": "qingyun_sect",      "name": "青云宗",   "type": "正道", "description": "正道第一仙门，坐拥青云山脉七峰，以剑修闻名天下。掌门青云真人化神境，门下弟子三千。", "worldTypeId": "cultivation", "associatedNpcs": ["senior_brother_li", "elder_qingyun", "sword_immortal_xuan"], "associatedQuests": ["main_intro_temple", "daily_clear_wolves", "daily_meditation", "visit_elder_quest", "sword_immortal_trial"] },
    { "id": "alchemy_guild",     "name": "丹霞宗",   "type": "正道", "description": "以炼丹术闻名修仙界，垄断了七成以上的丹药市场。宗主丹阳真人元婴境，门下丹师数百。", "worldTypeId": "cultivation", "associatedNpcs": ["alchemist_su"], "associatedQuests": ["alchemy_materials_quest"] },
    { "id": "sword_guild",       "name": "万剑阁",   "type": "正道", "description": "纯粹的剑修势力，阁中弟子终生只修一剑。不问世事，但剑道修为冠绝天下。", "worldTypeId": "cultivation", "associatedNpcs": ["sword_master_ye"], "associatedQuests": ["sword_guild_trial", "sword_master_duel"] },
    { "id": "demon_cult",        "name": "天魔教",   "type": "魔道", "description": "魔道第一势力，信奉天魔大道。教众行事狠辣果决，以战养战，对敌人毫不留情。", "worldTypeId": "cultivation", "associatedNpcs": ["demon_elder_mo"], "associatedQuests": ["demon_cult_initiation", "demon_cult_artifact_hunt"] },
    { "id": "rogue_cultivators", "name": "散修联盟", "type": "中立", "description": "由无数散修自发组成的互助组织，在各大坊市设有据点。鱼龙混杂，消息灵通。", "worldTypeId": "cultivation", "associatedNpcs": ["rogue_cultivator_hei"], "associatedQuests": ["hidden_secret_cave"] },
    { "id": "merchant_guild",    "name": "商会同盟", "type": "中立", "description": "跨域商贸势力，掌控灵石流通和珍稀资源交易。只要有灵石，在这里什么都能买到。", "worldTypeId": "cultivation", "associatedNpcs": ["merchant_wang"], "associatedQuests": ["side_collect_herbs", "side_rare_herb_hunt"] },
    { "id": "demon_beasts",      "name": "万妖谷",   "type": "魔道", "description": "妖族聚集之地，强者为尊。谷中妖族种类繁多，从刚化形的妖兽到元婴境大妖皆有。", "worldTypeId": "cultivation", "associatedNpcs": ["demon_beast_serpent", "beast_merchant_hu"], "associatedQuests": ["daily_beast_hunt"] },
    { "id": "buddhist_sect",     "name": "佛门禅宗", "type": "正道", "description": "隐于深山古刹的佛修势力，以慈悲为本，以降魔为用。功法独树一帜，不修灵力修佛力。", "worldTypeId": "cultivation", "associatedNpcs": ["monk_kongjian"], "associatedQuests": ["buddhist_temple_pilgrimage"] },
    { "id": "array_family",      "name": "阵法世家", "type": "中立", "description": "传承数千年的阵法世家，族中人人精通阵法之道。出售阵盘、阵旗，也承接护山大阵布置。", "worldTypeId": "cultivation", "associatedNpcs": ["array_master_zhao"], "associatedQuests": ["array_family_commission", "ancient_array_exploration"] },
    { "id": "intelligence_guild","name": "天机阁",   "type": "中立", "description": "神秘的情报组织，号称「无事不知天机阁」。贩卖消息、悬赏任务、刺杀委托，无所不接。", "worldTypeId": "cultivation", "associatedNpcs": ["intelligence_dealer_jiu"], "associatedQuests": ["bounty_hunt_demon_leader", "demon_cult_artifact_hunt"] },
    { "id": "ancient_clan",      "name": "古族遗民", "type": "中立", "description": "上古大战后遗留下来的远古氏族，隐世不出。血脉中蕴含上古秘术，族中子弟天赋异禀。", "worldTypeId": "cultivation", "associatedNpcs": ["ancient_elder_cang"], "associatedQuests": ["ancient_clan_investigation", "bloodline_awakening"] }
  ],

