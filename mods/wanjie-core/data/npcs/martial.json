    "dialogueLines": {
      "greeting": {
        "id": "greeting",
        "text": "哈哈，年轻人！想学功夫吗？老夫这里从基本功到绝世秘籍，应有尽有！",
        "options": [
          {
            "id": "train",
            "text": "请师傅指点一下练功方法",
            "statGates": [
              { "coreStat": "willpower", "minValue": 8, "failureHint": "需要至少 8 点毅力才能承受高强度训练" }
            ],
            "resultBranch": "training"
          },
          {
            "id": "spar",
            "text": "想和师傅过两招！",
            "minAttitude": 50,
            "resultBranch": "spar_offer"
          },
          { "id": "shop", "text": "看看有没有趁手的兵器", "resultBranch": "open_shop" },
          { "id": "leave", "text": "下次再来", "resultBranch": "__exit__" }
        ],
        "repeatable": true
      },
      "training": {
        "id": "training",
        "text": "好！记住了——外练筋骨皮，内练一口气。先扎马步一个时辰！",
        "options": [
          {
            "id": "accept",
            "text": "练！",
            "resultBranch": "greeting"
          }
        ],
        "repeatable": true,
        "cooldownSeconds": 600,
        "onEnter": ["give_physical_training_buff"]
      },
      "spar_offer": {
        "id": "spar_offer",
        "text": "好胆色！老夫只用三成功力，点到为止！",
        "options": [
          {
            "id": "fight",
            "text": "请！",
            "resultBranch": "__exit__"
          }
        ],
        "repeatable": true,
        "cooldownSeconds": 7200,
        "onEnter": ["trigger_spar_battle_dojo_master"]
      },
      "open_shop": {
        "id": "open_shop",
        "text": "兵器拳谱都在这里了，挑吧！",
        "options": [
          { "id": "back", "text": "再看看别的", "resultBranch": "greeting" }
        ],
        "repeatable": true
      }
    },
    "shopItems": [
