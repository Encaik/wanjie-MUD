    "dialogueLines": {
      "greeting": {
        "id": "greeting",
        "text": "哼，什么人？这地方可不是随便来的。",
        "options": [
          {
            "id": "intimidate",
            "text": "少废话，交出你手里的灵草！",
            "minAttitude": -80,
            "statGates": [
              { "coreStat": "physicalATK", "minValue": 20, "failureHint": "需要至少 20 点物理攻击才能威慑对方" }
            ],
            "resultBranch": "intimidated"
          },
          {
            "id": "trade",
            "text": "我来做交易的，听说你有好货？",
            "minAttitude": -30,
            "resultBranch": "open_black_market"
          },
          {
            "id": "greet_neutral",
            "text": "路过而已，并无恶意",
            "resultBranch": "neutral_response"
          },
          { "id": "leave", "text": "打扰了", "resultBranch": "__exit__" }
        ],
        "repeatable": true
      },
      "intimidated": {
        "id": "intimidated",
        "text": "别……别动手！灵草给你就是。",
        "options": [
          { "id": "take", "text": "算你识相", "resultBranch": "__exit__" }
        ],
        "repeatable": false,
        "onEnter": ["give_item_spirit_herb", "attitude_change_hostile_30"]
      },
      "open_black_market": {
        "id": "open_black_market",
        "text": "有点意思……没错，我手里有些市面上买不到的东西。不过价格嘛，可不便宜。",
        "options": [
          { "id": "browse", "text": "看看货", "resultBranch": "greeting" }
        ],
        "repeatable": true
      },
      "neutral_response": {
        "id": "neutral_response",
        "text": "行，既然不是来找麻烦的，我也不为难你。快走吧。",
        "options": [
          { "id": "ok", "text": "告辞", "resultBranch": "__exit__" }
        ],
        "repeatable": true
      }
    },
    "shopItems": [
