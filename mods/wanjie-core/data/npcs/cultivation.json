    "raceId": "human",
    "talentIds": [],
    "attitude": { "initialValue": -15, "changeRateModifier": 0.8 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "什么人？这地方可不是随便来的。", "options": [
        { "id": "intimidate", "text": "少废话，交出灵草！", "minAttitude": -80, "resultBranch": "intimidated" },
        { "id": "trade", "text": "我来做交易的，听说你有好货？", "minAttitude": -30, "resultBranch": "open_black_market" },
        { "id": "greet_neutral", "text": "路过而已，并无恶意", "resultBranch": "neutral_response" },
        { "id": "leave", "text": "打扰了", "resultBranch": "__exit__" }], "repeatable": true },
      "intimidated": { "id": "intimidated", "text": "别……别动手！灵草给你就是。", "options": [{ "id": "take", "text": "算你识相", "resultBranch": "__exit__" }], "repeatable": false, "onEnter": ["give_item_spirit_herb", "attitude_change_hostile_30"] },
      "open_black_market": { "id": "open_black_market", "text": "有点意思……我手里有些市面上买不到的东西。不过价格嘛，可不便宜。", "options": [{ "id": "browse", "text": "看看货", "resultBranch": "greeting" }], "repeatable": true },
      "neutral_response": { "id": "neutral_response", "text": "行，既然不是来找麻烦的，我也不为难你。快走吧。", "options": [{ "id": "ok", "text": "告辞", "resultBranch": "__exit__" }], "repeatable": true }
    },
    "shopItems": [{ "itemId": "forbidden_pill", "basePrice": 300, "quantity": 3, "maxQuantity": 3, "restockIntervalSeconds": 86400, "minAttitude": 0 }, { "itemId": "poison_dart", "basePrice": 50, "minAttitude": -20 }],
    "supportsAIDialogue": false,
    "combatBehavior": { "aggressionThreshold": -40, "fleeThreshold": 0.25, "combatStyle": "caster", "skillPriority": ["dark_spell_01", "dark_spell_02"] }
  },
  {
    "id": "demon_beast_serpent",
    "name": "赤鳞蟒妖",
    "description": "青云山脉中的妖兽，灵智已开，能口吐人言。性情暴戾，对闯入领地者毫不留情。",
    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "demon_beasts",
    "attributes": { "constitution": 20, "insight": 6, "luck": 5, "willpower": 18, "spiritPower": 4 },
    "coreStats": { "maxHp": 120, "physicalATK": 30, "specialATK": 8, "physicalDEF": 25, "specialDEF": 8, "speed": 22, "intelligence": 6, "willpower": 18, "lifespan": 500, "perception": 20, "specialResourceCap": 40 },
    "raceId": "demon",
    "talentIds": [],
    "attitude": { "initialValue": -70, "changeRateModifier": 0.3 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "嘶嘶嘶……人类，竟敢踏入吾之领地！", "options": [
        { "id": "fight", "text": "妖兽受死！", "resultBranch": "__exit__" },
        { "id": "offer", "text": "我是来献祭的，这枚灵果献给您", "check": { "type": "attribute", "target": "insight", "difficulty": 14 }, "resultBranch": "pacified" },
        { "id": "flee", "text": "快跑！", "resultBranch": "__exit__" }], "repeatable": true },
      "pacified": { "id": "pacified", "text": "……算你识相。山腰的千年灵芝你可以取走，但别再来了。", "options": [{ "id": "thanks", "text": "多谢蛇仙大人", "resultBranch": "__exit__" }], "repeatable": false, "onEnter": ["unlock_herb_location"] },
      "enraged": { "id": "enraged", "text": "找死！！", "options": [{ "id": "battle", "text": "迎战！", "resultBranch": "__exit__" }], "repeatable": false, "onEnter": ["trigger_boss_battle_serpent"] }
    },
