    "coreStats": { "maxHp": 36, "physicalATK": 13, "specialATK": 6, "physicalDEF": 8, "specialDEF": 10, "speed": 8, "intelligence": 12, "willpower": 8, "lifespan": 80, "perception": 10, "specialResourceCap": 0 },
    "raceId": "human",
    "talentIds": ["merchantMind"],
    "attitude": { "initialValue": 10, "changeRateModifier": 1.2 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "哟，客官来啦！小店虽小，但灵丹妙药应有尽有。想看看什么？", "options": [
        { "id": "browse_shop", "text": "看看有什么好东西", "resultBranch": "open_shop" },
        { "id": "ask_discount", "text": "王掌柜，老顾客了，打个折呗？", "minAttitude": 50, "check": { "type": "attribute", "target": "insight", "difficulty": 10 }, "resultBranch": "discount_shop" },
        { "id": "chat_world", "text": "王掌柜走南闯北，可听说过什么奇闻异事？", "minAttitude": 20, "resultBranch": "gossip" },
        { "id": "leave", "text": "告辞", "resultBranch": "__exit__" }], "repeatable": true },
      "open_shop": { "id": "open_shop", "text": "请随意挑选，价格公道！", "options": [{ "id": "leave_shop", "text": "好，再看看别的", "resultBranch": "greeting" }], "repeatable": true },
      "gossip": { "id": "gossip", "text": "最近青云山脉那边不太平，听说有妖兽出没。据说那妖兽守护着一株千年灵芝……", "options": [{ "id": "interested", "text": "详细说说位置", "resultBranch": "gossip_detail" }, { "id": "not_interested", "text": "多谢提醒", "resultBranch": "greeting" }], "repeatable": true },
      "gossip_detail": { "id": "gossip_detail", "text": "往东三十里，青云山脉第三峰。不过那妖兽至少筑基期才敢去。", "options": [{ "id": "acknowledge", "text": "知道了，多谢掌柜！", "resultBranch": "greeting" }], "repeatable": false, "onEnter": ["unlock_quest_qingyun_herb"] }
    },
    "shopItems": [
      { "itemId": "healing_pill_low", "basePrice": 30, "quantity": 20, "maxQuantity": 20, "restockIntervalSeconds": 1800 },
      { "itemId": "healing_pill_mid", "basePrice": 80, "quantity": 10, "maxQuantity": 10, "restockIntervalSeconds": 3600 },
      { "itemId": "mana_pill_low", "basePrice": 25, "quantity": 15, "maxQuantity": 15, "restockIntervalSeconds": 1800 },
      { "itemId": "cultivation_pill", "basePrice": 100, "quantity": 5, "maxQuantity": 5, "restockIntervalSeconds": 7200 },
      { "itemId": "breakthrough_pill", "basePrice": 500, "quantity": 1, "maxQuantity": 1, "restockIntervalSeconds": 86400, "minAttitude": 40 }
    ],
