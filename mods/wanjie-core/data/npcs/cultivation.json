  {
    "id": "elder_qingyun",
    "name": "青云真人",
    "description": "青云宗掌门，修为已至化神境。仙风道骨，深不可测。轻易不出关，但偶尔会指点有缘的弟子。",
    "worldviewRestrictions": ["cultivation"],
    "factionId": "righteous_sect",
    "attributes": { "constitution": 25, "insight": 30, "luck": 20, "willpower": 28, "spiritPower": 35 },
    "coreStats": { "maxHp": 200, "physicalATK": 55, "specialATK": 80, "physicalDEF": 40, "specialDEF": 50, "speed": 28, "intelligence": 35, "willpower": 40, "lifespan": 800, "perception": 30, "specialResourceCap": 500 },
    "raceId": "human",
    "talentIds": ["daoHeart", "spiritualGift", "spiritWisdom"],
    "attitude": { "initialValue": 30, "changeRateModifier": 0.5 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "年轻人，你身上有一股不凡的气息。来找本座可是为了求道？", "options": [
        { "id": "ask_dao", "text": "请真人指点大道", "minAttitude": 40, "check": { "type": "coreStat", "target": "willpower", "difficulty": 18 }, "resultBranch": "teach_dao" },
        { "id": "ask_secret", "text": "听说此界之外还有万界？", "minAttitude": 60, "resultBranch": "tell_ascension" },
        { "id": "offer_gift", "text": "晚辈带来一株千年灵芝孝敬真人", "minAttitude": 20, "resultBranch": "accept_gift" },
        { "id": "leave", "text": "不敢打扰真人清修", "resultBranch": "__exit__" }], "repeatable": true },
      "teach_dao": { "id": "teach_dao", "text": "道可道，非常道。你且记住：修行不是为了变强，而是为了看清自己。心若明镜，则万物皆可为师。", "options": [{ "id": "enlightened", "text": "弟子明白了！", "resultBranch": "greeting" }], "repeatable": true, "cooldownSeconds": 7200, "onEnter": ["give_major_cultivation_buff", "attitude_change_friendly_10"] },
      "tell_ascension": { "id": "tell_ascension", "text": "不错，此界之外确有无穷万界。渡劫飞升之后，便能踏足万界之旅。但切记：飞升容易，回头难。", "options": [{ "id": "determined", "text": "我一定会踏上万界之路！", "resultBranch": "greeting" }], "repeatable": false, "onEnter": ["give_ascension_knowledge_buff"] },
      "accept_gift": { "id": "accept_gift", "text": "千年灵芝……不错，你有心了。本座便传你一道剑意，好生领悟。", "options": [{ "id": "thank", "text": "多谢真人赐教！", "resultBranch": "greeting" }], "repeatable": false, "onEnter": ["give_sword_insight", "attitude_change_friendly_15"] }
    },
    "shopItems": [],
    "supportsAIDialogue": true,
    "combatBehavior": { "aggressionThreshold": -30, "fleeThreshold": 0, "combatStyle": "caster", "skillPriority": ["supreme_sword_art", "heavenly_lightning"] }
  },
  {
    "id": "alchemist_su",
    "name": "苏丹师",
    "description": "丹霞宗炼丹长老，痴迷于炼丹术，常年守在丹炉旁。脾气古怪但对丹道极有见地。",
    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "alchemy_guild",
    "attributes": { "constitution": 10, "insight": 18, "luck": 15, "willpower": 12, "spiritPower": 14 },
    "coreStats": { "maxHp": 45, "physicalATK": 14, "specialATK": 25, "physicalDEF": 10, "specialDEF": 16, "speed": 10, "intelligence": 22, "willpower": 14, "lifespan": 150, "perception": 12, "specialResourceCap": 100 },
    "raceId": "human",
    "talentIds": ["quickLearner", "luckyStar"],
    "attitude": { "initialValue": 0, "changeRateModifier": 1.0 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "谁啊？没看我正忙着呢！这炉丹还差半个时辰——嗯？你是来求丹的？", "options": [
        { "id": "ask_pill", "text": "想请教炼丹之道", "minAttitude": 20, "resultBranch": "teach_alchemy" },
        { "id": "commission", "text": "想请苏丹师定制一枚丹药", "minAttitude": 40, "resultBranch": "take_commission" },
        { "id": "donate_herbs", "text": "我这里有些灵草，愿意捐给苏丹师", "resultBranch": "accept_herbs" },
        { "id": "leave", "text": "不打扰了", "resultBranch": "__exit__" }], "repeatable": true },
      "teach_alchemy": { "id": "teach_alchemy", "text": "炼丹讲究火候、配比、时机。三味缺一不可。你若有心，先学会辨认灵草再来。", "options": [{ "id": "ok", "text": "多谢指点", "resultBranch": "greeting" }], "repeatable": true, "cooldownSeconds": 600, "onEnter": ["give_alchemy_knowledge"] },
      "take_commission": { "id": "take_commission", "text": "定制丹药？行啊，不过材料得你自己出。我最近缺凤凰羽和龙涎草，你若有，我帮你炼一枚破境丹。", "options": [{ "id": "accept", "text": "我去找材料", "resultBranch": "greeting" }], "repeatable": false, "onEnter": ["unlock_quest_alchemy_materials"] },
      "accept_herbs": { "id": "accept_herbs", "text": "哦？让我看看……这些灵草品相不错！这枚聚气丹就当谢礼了。", "options": [{ "id": "thanks", "text": "多谢苏丹师", "resultBranch": "greeting" }], "repeatable": true, "cooldownSeconds": 86400, "onEnter": ["give_cultivation_pill", "attitude_change_friendly_5"] }
    },
    "shopItems": [{ "itemId": "breakthrough_pill", "basePrice": 400, "quantity": 2, "maxQuantity": 2, "restockIntervalSeconds": 86400, "minAttitude": 30 }],
    "supportsAIDialogue": false,
    "combatBehavior": { "aggressionThreshold": -70, "fleeThreshold": 0.4, "combatStyle": "support", "skillPriority": [] }
  },
  {
    "id": "sword_immortal_xuan",
    "name": "剑玄仙子",
