  {
    "id": "senior_brother_li",
    "name": "李师兄",
    "description": "宗门内门弟子，修为已达金丹期。为人正直，乐于指点后辈修炼。",
    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "righteous_sect",
    "attributes": { "constitution": 15, "insight": 16, "luck": 10, "willpower": 14, "spiritPower": 18 },
    "coreStats": { "maxHp": 80, "physicalATK": 25, "specialATK": 36, "physicalDEF": 20, "specialDEF": 28, "speed": 18, "intelligence": 16, "willpower": 14, "lifespan": 200, "perception": 14, "specialResourceCap": 150 },
    "raceId": "human",
    "talentIds": ["swordHeart"],
    "attitude": { "initialValue": 25, "changeRateModifier": 1.0 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "师弟/师妹来了。修行路上可有什么困惑？", "options": [
        { "id": "ask_cultivation", "text": "请教师兄修炼心得", "resultBranch": "teach_cultivation" },
        { "id": "ask_spar", "text": "想和师兄切磋一番", "minAttitude": 40, "resultBranch": "spar_confirm" },
        { "id": "ask_sect", "text": "师兄，咱们宗门有什么大人物吗？", "minAttitude": 20, "resultBranch": "tell_sect" },
        { "id": "greet_leave", "text": "只是来看看师兄", "resultBranch": "__exit__" }], "repeatable": true },
      "teach_cultivation": { "id": "teach_cultivation", "text": "心静则气顺，气顺则丹成。每日打坐一个时辰，胜过囫囵吞枣十枚丹药。", "options": [{ "id": "thank", "text": "多谢师兄指点", "resultBranch": "greeting" }], "repeatable": true, "cooldownSeconds": 600, "onEnter": ["give_cultivation_buff_1h"] },
      "tell_sect": { "id": "tell_sect", "text": "咱们青云宗最厉害的当然是掌门青云真人，化神境的大能！藏书阁的守阁长老也是元婴境的高手。", "options": [{ "id": "interested", "text": "元婴境……真是令人向往", "resultBranch": "greeting" }], "repeatable": true, "onEnter": ["unlock_quest_visit_elder"] },
      "spar_confirm": { "id": "spar_confirm", "text": "好！点到为止，让我看看你最近的进步。", "options": [{ "id": "fight", "text": "请师兄赐教！", "resultBranch": "__exit__" }], "repeatable": true, "cooldownSeconds": 3600, "onEnter": ["trigger_spar_battle_senior_li"] }
    },
    "shopItems": [],
    "supportsAIDialogue": false,
    "combatBehavior": { "aggressionThreshold": -60, "fleeThreshold": 0.1, "combatStyle": "melee", "skillPriority": ["sword_technique_01", "sword_technique_02"] }
  },
  {
    "id": "rogue_cultivator_hei",
    "name": "黑风散修",
