    "raceId": "demon",
    "talentIds": ["demonicPhysique", "predatorInstinct"],
    "attitude": { "initialValue": 5, "changeRateModifier": 1.5 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "哈哈哈！人类修士！来来来，喝酒喝酒！喝完再谈买卖！", "options": [
        { "id": "drink", "text": "好！干了！", "resultBranch": "drink_together" },
        { "id": "browse", "text": "虎掌柜，我听说你这有好东西？", "minAttitude": 10, "resultBranch": "show_wares" },
        { "id": "gift_wine", "text": "我带了上好的灵酒，孝敬虎掌柜", "resultBranch": "accept_wine" },
        { "id": "leave", "text": "下次再来喝酒", "resultBranch": "__exit__" }], "repeatable": true },
