[
  {
    "id": "merchant_wang",
    "name": "王掌柜",
    "description": "坊市丹药铺的老板，精于商道，见钱眼开但为人还算公道。对各种灵药了如指掌。",
    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "merchant_guild",
    "attributes": {
      "体质": 8,
      "灵根": 6,
      "悟性": 10,
      "幸运": 12,
      "意志": 8
    },
    "coreStats": {
      "maxHp": 36,
      "physicalATK": 13,
      "specialATK": 6,
      "physicalDEF": 8,
      "specialDEF": 10,
      "speed": 8,
      "intelligence": 12,
      "willpower": 8,
      "lifespan": 80,
      "perception": 10,
      "specialResourceCap": 0
    },
    "raceId": "human",
    "talentIds": ["merchant_insight"],
    "attitude": {
      "initialValue": 10,
      "changeRateModifier": 1.2
    },
    "dialogueLines": {
      "greeting": {
        "id": "greeting",
        "text": "哟，客官来啦！小店虽小，但灵丹妙药应有尽有。想看看什么？",
        "options": [
          {
            "id": "browse_shop",
            "text": "看看有什么好东西",
            "resultBranch": "open_shop"
          },
          {
            "id": "ask_discount",
            "text": "王掌柜，老顾客了，打个折呗？",
            "minAttitude": 50,
            "statGates": [
              { "coreStat": "intelligence", "minValue": 10, "failureHint": "需要至少 10 点智力才能讨价还价" }
            ],
            "check": {
              "type": "attribute",
              "target": "悟性",
              "difficulty": 10,
              "successText": "王掌柜眯眼一笑：'行吧行吧，老顾客了，给你打个八折！'",
              "failureText": "王掌柜摆摆手：'小本生意，概不赊账，也不打折。'",
              "successBranch": "discount_shop",
              "failureBranch": "open_shop"
            },
            "resultBranch": "discount_shop"
          },
          {
            "id": "chat_world",
            "text": "王掌柜走南闯北，可听说过什么奇闻异事？",
            "minAttitude": 20,
            "resultBranch": "gossip"
          },
          {
            "id": "leave",
            "text": "告辞",
            "resultBranch": "__exit__"
          }
        ],
        "repeatable": true
      },
      "open_shop": {
        "id": "open_shop",
        "text": "请随意挑选，价格公道！",
        "options": [
          { "id": "leave_shop", "text": "好，再看看别的", "resultBranch": "greeting" }
        ],
        "repeatable": true
      },
      "discount_shop": {
        "id": "discount_shop",
        "text": "好好好，既然是老主顾，今日给你打八折！挑吧。",
        "options": [
          { "id": "leave_discount", "text": "多谢掌柜！", "resultBranch": "greeting" }
        ],
        "repeatable": true,
        "cooldownSeconds": 3600
      },
      "gossip": {
        "id": "gossip",
        "text": "嘿，最近青云山脉那边不太平，听说有妖兽出没。不过据说那妖兽守护着一株千年灵芝……要不要去碰碰运气？",
        "options": [
          {
            "id": "interested",
            "text": "详细说说位置",
            "resultBranch": "gossip_detail"
          },
          { "id": "not_interested", "text": "多谢提醒，我会小心的", "resultBranch": "greeting" }
        ],
        "repeatable": true
      },
      "gossip_detail": {
        "id": "gossip_detail",
        "text": "从这儿往东走三十里，青云山脉第三峰。不过丑话说在前头，那妖兽可不好惹，至少得筑基期的修为才敢去。",
        "options": [
          { "id": "acknowledge", "text": "知道了，多谢王掌柜！", "resultBranch": "greeting" }
        ],
        "repeatable": false,
        "onEnter": ["unlock_quest_qingyun_herb"]
      }
    },
    "shopItems": [
      { "itemId": "healing_pill_low", "basePrice": 30, "quantity": 20, "maxQuantity": 20, "restockIntervalSeconds": 1800 },
      { "itemId": "healing_pill_mid", "basePrice": 80, "quantity": 10, "maxQuantity": 10, "restockIntervalSeconds": 3600 },
      { "itemId": "mana_pill_low", "basePrice": 25, "quantity": 15, "maxQuantity": 15, "restockIntervalSeconds": 1800 },
      { "itemId": "cultivation_pill", "basePrice": 100, "quantity": 5, "maxQuantity": 5, "restockIntervalSeconds": 7200 },
      { "itemId": "breakthrough_pill", "basePrice": 500, "quantity": 1, "maxQuantity": 1, "restockIntervalSeconds": 86400, "minAttitude": 40 },
      { "itemId": "spirit_stone_small", "basePrice": 10, "minAttitude": 0 }
    ],
    "supportsAIDialogue": false,
    "combatBehavior": {
      "aggressionThreshold": -80,
      "fleeThreshold": 0.3,
      "combatStyle": "support",
      "skillPriority": []
    }
  },
  {
    "id": "senior_brother_li",
    "name": "李师兄",
    "description": "宗门内门弟子，修为已达金丹期。为人正直，乐于指点后辈修炼。",
    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "righteous_sect",
    "attributes": {
      "体质": 15,
      "灵根": 18,
      "悟性": 16,
      "幸运": 10,
      "意志": 14
    },
    "coreStats": {
      "maxHp": 80,
      "physicalATK": 25,
      "specialATK": 36,
      "physicalDEF": 20,
      "specialDEF": 28,
      "speed": 18,
      "intelligence": 16,
      "willpower": 14,
      "lifespan": 200,
      "perception": 14,
      "specialResourceCap": 150
    },
    "raceId": "human",
    "talentIds": ["sword_mastery"],
    "attitude": {
      "initialValue": 25,
      "changeRateModifier": 1.0
    },
    "dialogueLines": {
      "greeting": {
        "id": "greeting",
        "text": "师弟/师妹来了啊。修行路上可有什么困惑？",
        "options": [
          {
            "id": "ask_cultivation",
            "text": "请教师兄修炼心得",
            "statGates": [
              { "coreStat": "willpower", "minValue": 10, "failureHint": "需要至少 10 点毅力才能领悟高深心法" }
            ],
            "resultBranch": "teach_cultivation"
          },
          {
            "id": "ask_spar",
            "text": "想和师兄切磋一番",
            "minAttitude": 40,
            "resultBranch": "spar_confirm"
          },
          { "id": "greet_leave", "text": "只是来看看师兄", "resultBranch": "__exit__" }
        ],
        "repeatable": true
      },
      "teach_cultivation": {
        "id": "teach_cultivation",
        "text": "修炼之道，贵在坚持。你且记下：心静则气顺，气顺则丹成。每日打坐一个时辰，胜过囫囵吞枣十枚丹药。",
        "options": [
          {
            "id": "thank",
            "text": "多谢师兄指点",
            "resultBranch": "greeting"
          }
        ],
        "repeatable": true,
        "cooldownSeconds": 600,
        "onEnter": ["give_cultivation_buff_1h"]
      },
      "spar_confirm": {
        "id": "spar_confirm",
        "text": "好！点到为止，让我看看你最近的进步。",
        "options": [
          {
            "id": "fight",
            "text": "请师兄赐教！",
            "resultBranch": "__exit__"
          }
        ],
        "repeatable": true,
        "cooldownSeconds": 3600,
        "onEnter": ["trigger_spar_battle_senior_li"]
      }
    },
    "shopItems": [],
