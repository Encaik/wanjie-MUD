    "worldviewRestrictions": ["cultivation", "xianxia"],
    "factionId": "righteous_sect",
    "attributes": { "constitution": 18, "insight": 24, "luck": 12, "willpower": 20, "spiritPower": 22 },
    "coreStats": { "maxHp": 100, "physicalATK": 45, "specialATK": 50, "physicalDEF": 28, "specialDEF": 30, "speed": 32, "intelligence": 20, "willpower": 25, "lifespan": 400, "perception": 22, "specialResourceCap": 200 },
    "raceId": "human",
    "talentIds": ["swordHeart", "daoHeart"],
    "attitude": { "initialValue": 0, "changeRateModifier": 0.6 },
    "dialogueLines": {
      "greeting": { "id": "greeting", "text": "……何事？若是闲聊，恕不奉陪。若是论剑，尚可一谈。", "options": [
        { "id": "challenge", "text": "我想挑战仙子的剑法！", "minAttitude": 50, "resultBranch": "accept_challenge" },
        { "id": "learn_sword", "text": "请仙子传授剑道真谛", "minAttitude": 70, "check": { "type": "attribute", "target": "insight", "difficulty": 16 }, "resultBranch": "teach_sword" },
        { "id": "gift_sword_manual", "text": "晚辈得了一本剑谱，想请仙子鉴赏", "minAttitude": 20, "resultBranch": "appraise_manual" },
        { "id": "leave", "text": "打扰仙子了", "resultBranch": "__exit__" }], "repeatable": true },
      "accept_challenge": { "id": "accept_challenge", "text": "勇气可嘉。出剑吧，我会把修为压到和你同境。", "options": [{ "id": "fight", "text": "请仙子赐教！", "resultBranch": "__exit__" }], "repeatable": true, "cooldownSeconds": 7200, "onEnter": ["trigger_spar_battle_sword_immortal"] },
      "teach_sword": { "id": "teach_sword", "text": "剑道即心道。心若不正，剑亦不正。记住：手中无剑，心中有剑，方为大成。", "options": [{ "id": "enlightened", "text": "剑心通明……我悟了", "resultBranch": "greeting" }], "repeatable": false, "onEnter": ["give_sword_mastery_permanent"] },
      "appraise_manual": { "id": "appraise_manual", "text": "这剑谱……竟有几分上古剑意的影子。虽然不是原本，但足够你修炼一阵了。", "options": [{ "id": "thanks", "text": "多谢仙子指点", "resultBranch": "greeting" }], "repeatable": false, "cooldownSeconds": 604800, "onEnter": ["attitude_change_friendly_20"] }
    },
    "shopItems": [],
    "supportsAIDialogue": false,
    "combatBehavior": { "aggressionThreshold": -40, "fleeThreshold": 0, "combatStyle": "melee", "skillPriority": ["supreme_sword_art", "sword_dance", "blade_storm"] }
  },
  {
    "id": "beast_merchant_hu",
    "name": "虎掌柜",
