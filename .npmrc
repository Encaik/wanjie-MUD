loglevel=error

strictStorePkgContentCheck=false
verifyStoreIntegrity=false

# 网络优化
network-concurrency=16
fetch-retries=3
fetch-timeout=60000

# 严格使用 peer dependencies
strict-peer-dependencies=false

# 自动生成 lockfile
auto-install-peers=true

# lockfile 配置
lockfile=true
prefer-frozen-lockfile=true

# 如果 lockfile 存在但过期，更新而不是失败
resolution-mode=highest

# better-sqlite3 的原生模块编译需要 VS Build Tools（Windows）
# 项目使用 sql.js (WASM) 作为底层 SQLite 实现，
# better-sqlite3 仅被 drizzle-orm 导入类型/包装代码，无需编译原生绑定
neverBuiltDependencies=["better-sqlite3"]
